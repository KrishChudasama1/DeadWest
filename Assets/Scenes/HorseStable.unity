  m_Script: {fileID: 11500000, guid: d6a8dbf2e2fcc4dc89614d93c71eec49, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NPCDialogue
  lines:
  - text: '"Well now, you ain''t from around here, are ya?"'
  - text: '"Heard tell there''s a lasso layin'' somewhere in the yard go find it."'
  - text: '"When you get it, open your inventory and equip the lasso."'
  - text: '"Press L to throw it you''ll need it on the Rider."'
  - text: '"Clear the enemy waves first, then slip through the back gate to reach
      the Rider''s track."'
  - text: '"Don''t hang about; the Rider won''t give you a second chance."'
  dialogueBox: {fileID: 1166235640}
  dialogueText: {fileID: 590725913}
  promptText: {fileID: 1364505258}
  typingSpeed: 0.04
  triggerDistance: 2
  interactKey: 121
  fadeAfterDialogue: 1
  fadeDelay: 0.2
  fadeDuration: 0.8
  autoStart: 0
  oneShot: 1
  lockPlayerDuringDialogue: 1
  audioMixer: {fileID: 0}
  dialogueTransitionSpeed: 0.5
